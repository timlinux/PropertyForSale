# PropertyForSale Backend Configuration
# Copy this file to .env and fill in the values

# Environment (development, staging, production)
ENV=development

# Server Configuration
PORT=8080
CORS_ORIGINS=http://localhost:5173
TRUSTED_PROXIES=

# Database (PostgreSQL + PostGIS)
DB_HOST=localhost
DB_PORT=5432
DB_USER=propertyforsale
DB_PASSWORD=propertyforsale
DB_NAME=propertyforsale
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# OAuth2 Providers
# Google
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/google/callback

# Apple
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=
OAUTH_APPLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/apple/callback

# Microsoft
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_CALLBACK_URL=http://localhost:8080/api/v1/auth/microsoft/callback

# GitHub
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_CALLBACK_URL=http://localhost:8080/api/v1/auth/github/callback

# Facebook
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_FACEBOOK_CALLBACK_URL=http://localhost:8080/api/v1/auth/facebook/callback

# S3/MinIO Storage
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=propertyforsale
S3_REGION=us-east-1
S3_USE_SSL=false
S3_PUBLIC_URL=http://localhost:9000/propertyforsale

# GeoIP (MaxMind)
GEOIP_DB_PATH=/var/lib/GeoIP/GeoLite2-City.mmdb
